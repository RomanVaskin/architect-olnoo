# Server-only — never prefixed with NEXT_PUBLIC_, never sent to the browser.
# Required in production; local dev without it falls back to loopback-only auth bypass.
GEMINI_API_KEY=

# Server-only, optional — model registry falls back to a built-in default when unset.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_REVIEW_MODEL=gemini-2.5-flash

# Public (NEXT_PUBLIC_) — safe to expose to the browser by design.
# The publishable key is scoped by Supabase RLS; it is never a service-role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public — the deployed app's own origin, no trailing slash.
# Used as the Supabase email-confirmation redirect base (falls back to the
# request's Origin header, then localhost, if unset). Must match a URL in
# Supabase Auth's allowed redirect list for the production project.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
